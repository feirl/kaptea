# --- pattern / WordPress catch-alls (after exacts) ---
RedirectMatch 301 ^/conversations-for-action/page/[0-9]+/?$ /pronto
RedirectMatch 301 ^/omnichannel-engagement/[^/]+/?$ /blog
RedirectMatch 301 ^/blog/page/[0-9]+/?$ /blog
RedirectMatch 301 ^/category/[^/]+/?$ /blog
RedirectMatch 301 ^/author/[^/]+/?$ /blog
RedirectMatch 301 ^/project_category/[^/]+(/page/[0-9]+)?/?$ /blog
RedirectMatch 301 ^/resource/[^/]+/?$ /blog
RedirectMatch 301 ^/page/[0-9]+/?$ /
RedirectMatch 301 ^/wp-admin(/.*)?$ /
RedirectMatch 301 ^/wp-json(/.*)?$ /
RedirectMatch 301 ^/wp-content(/.*)?$ /
RedirectMatch 301 ^/proposal(/.*)?$ /

# --- 3. Truncated / never-real URLs from GSC: 410 Gone (anchored!) --------
#  Anchored ^...$ so they can NOT match real pages like /twilio-partner
#  or /customer-journey-orchestration.
RedirectMatch 410 ^/customer-$
RedirectMatch 410 ^/twilio-$
RedirectMatch 410 ^/cdn-cgi/l/email-protection$
