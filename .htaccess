# ============================================================================
#  kaptea.io  .htaccess  -- legacy URL 301 redirects + host hygiene
#  Ported from vercel.json (which only ever applied to staging, never live)
#  plus gaps found in Google Search Console. Every destination verified 200.
#  MERGE into the existing server .htaccess; do not blindly overwrite.
# ============================================================================

# --- 1. Canonical host + HTTPS (OPTIONAL) --------------------------------
#  Cloudflare already 301s www -> apex on kaptea.io. Enable ONLY if you
#  confirm it is not, to avoid redirect chains.
#
#  RewriteEngine On
#  RewriteCond %{HTTP_HOST} ^www\.kaptea\.io [NC]
#  RewriteRule ^(.*)$ https://kaptea.io/$1 [R=301,L]

# --- 2. Legacy 301 redirects (mod_alias, exact-anchored) -----------------
